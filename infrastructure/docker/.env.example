# StreamKit - Environment Variables
# Copy to .env and adjust values

# ── General ──
NODE_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL ──
POSTGRES_USER=streamkit
POSTGRES_PASSWORD=streamkit_secret
POSTGRES_DB=streamkit
POSTGRES_PORT=5432

# ── MongoDB ──
MONGO_USER=streamkit
MONGO_PASSWORD=streamkit_secret
MONGO_DB=streamkit
MONGODB_PORT=27017

# ── Redis ──
REDIS_PASSWORD=streamkit_secret
REDIS_PORT=6379

# ── Kafka ──
KAFKA_PORT=9092

# ── MinIO (S3-compatible) ──
MINIO_ROOT_USER=streamkit
MINIO_ROOT_PASSWORD=streamkit_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── JWT ──
JWT_SECRET=change-me-in-production-please
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# ── Service Ports ──
API_GATEWAY_PORT=3000
WS_GATEWAY_PORT=3100
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
CHAT_SERVICE_PORT=3003
CALL_SERVICE_PORT=3004
MEETING_SERVICE_PORT=3005
STREAM_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
PRESENCE_SERVICE_PORT=3008
MEDIA_SERVICE_PORT=3009
ANALYTICS_SERVICE_PORT=3010
MODERATION_SERVICE_PORT=3011
SIGNALING_SERVER_PORT=3012

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── TURN/STUN ──
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=
STUN_SERVER_URL=stun:stun.l.google.com:19302

# ── Push Notifications ──
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# ── Email (SMTP) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@streamkit.io
