{
  "name": "@rajutechie-streamkit/js-sdk",
  "version": "0.1.0",
  "description": "RajutechieStreamKit JavaScript SDK for browser-based real-time communication",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser/index.mjs",
      "require": "./dist/browser/index.js",
      "types": "./dist/browser/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/browser/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/browser/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@rajutechie-streamkit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajutechie-streamkit/rajutechie-streamkit.git",
    "directory": "packages/js-sdk"
  },
  "keywords": [
    "rajutechie-streamkit",
    "realtime",
    "chat",
    "video",
    "webrtc",
    "javascript",
    "browser",
    "sdk"
  ]
}
