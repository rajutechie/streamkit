generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  secret    String
  name      String
  appId     String   @default("default")
  isActive  Boolean  @default(true)
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
